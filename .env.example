# Django
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=<generate-with: python3 -c "import secrets; print(secrets.token_urlsafe(50))">
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
POSTGRES_DB=station_manager
POSTGRES_USER=station_manager
POSTGRES_PASSWORD=station_manager
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Redis (for Django Channels — WebSocket/live status/terminal/deployment progress)
REDIS_HOST=redis
REDIS_PORT=6379

# Language
DJANGO_LANGUAGE_CODE=en

# Alert notifications — Email
ALERT_EMAIL_ENABLED=false
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM=alerts@oe5xrx.org

# Alert notifications — Telegram
ALERT_TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Provisioning / images
LINUX_IMAGE_REPO=OE5XRX/linux-image
SERVER_PUBLIC_URL=https://ham.oe5xrx.org

# S3-compatible object storage (Hetzner Object Storage, AWS S3, MinIO)
# Required in production for the images + provisioning apps:
#   - images/<tag>/<machine>.wic.bz2       base images
#   - provisioning/<uuid>/*.wic.bz2        per-station bundles (ephemeral)
# Leave USE_S3=false to use local media storage instead (dev only).
USE_S3=false
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET_NAME=
S3_ENDPOINT_URL=
S3_REGION=
